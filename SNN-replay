# Flatten the grid arrays
x_positions = grid_x.flatten()
y_positions = grid_y.flatten()

# neurons
Neuron_eqs =  """ dv/dt = (0.04*v**2 + 5*v + 140 - u + I )/ms : 1
                  du/dt = (a*(b*v - u))/ms  : 1
                  I : 1
                  a : 1
                  b : 1
                  c : 1
                  d : 1
              """

Neuron_eqs_DD = """ dv/dt = (0.04*v**2 + 5*v + 140 - u + I )/ms : 1
                    du/dt = (a*(b*v - u))/ms  : 1
                    I : 1
                    a : 1
                    b : 1
                    c : 1
                    d : 1
                    x : 1  # x-position of neuron
                    y : 1  # y-position of neuron
                """

Place_Cell       = NeuronGroup(N_neurons, Neuron_eqs , threshold="v>=30", reset="v=c; u+=d", method="euler")
Memory           = NeuronGroup(N_neurons, Neuron_eqs , threshold="v>=30", reset="v=c; u+=d", method="euler")
Reward_Cell      = NeuronGroup(N_neurons, Neuron_eqs_DD , threshold="v>=30", reset="v=c; u+=d", method="euler")
Boundary_Cell    = NeuronGroup(N_neurons, Neuron_eqs , threshold="v>=30", reset="v=c; u+=d", method="euler")

Place_Cell.a = 0.1
Place_Cell.b = 0.2
Place_Cell.c = -65
Place_Cell.d = 2

Memory.a = 0.1
Memory.b = 0.2
Memory.c = -65
Memory.d = 2

Reward_Cell.a = 0.1
Reward_Cell.b = 0.2
Reward_Cell.c = -65
Reward_Cell.d = 2

