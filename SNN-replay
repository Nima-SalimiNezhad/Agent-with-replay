##############################################################################################
# synapses
Syn_PC_PC   = Synapses(Place_Cell, Place_Cell,
                        '''
                        w       : 1
                        wmax    : 1
                        Apre    : 1
                        Apost   : 1
                        taupre  : second
                        taupost : second
                        k       : 1

                        dapre/dt = -apre/taupre : 1 (event-driven)
                        dapost/dt = -apost/taupost : 1 (event-driven)
                        ''',
                        on_pre='''
                        v_post += w
                        apre += Apre
                        w = clip(w+(apost*k), 0, wmax)
                        ''',
                        on_post='''
                        apost += Apost
                        w = clip(w+(apre*k), 0, wmax)
                        ''', method='linear')

Syn_PC_Mem  = Synapses(Place_Cell, Memory, 'w : 1', on_pre='v_post += w ', method='linear')

Syn_Mem_Mem = Synapses(Memory, Memory,
                        '''
                        w       : 1
                        wmax    : 1
                        Apre    : 1
                        Apost   : 1
                        taupre  : second
                        taupost : second
                        k       : 1

                        dapre/dt = -apre/taupre : 1 (event-driven)
                        dapost/dt = -apost/taupost : 1 (event-driven)
                        ''',
                        on_pre='''
                        v_post += w
                        apre += Apre
                        w = clip(w+(apost*k), 0, wmax)
                        ''',
                        on_post='''
                        apost += Apost
